# Default login credentials
VITE_USERNAME=klikadmin
VITE_PASSWORD=klikadmin

# ─── Google Service Account ───────────────────────────────────────────────────
# For Sheets operations (used by browser, so needs VITE_ prefix):
VITE_GOOGLE_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
VITE_GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# For image proxy via /api/drive-image (server-only, NO VITE_ prefix = never in browser):
GOOGLE_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# ─────────────────────────────────────────────────────────────────────────────
